---
import "../styles/global.css";

import { ClientRouter } from "astro:transitions";

interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "The Architect's Blueprint - The latest in tech infrastructure and architecture.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <ClientRouter />
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <nav class="sticky top-0 z-50 bg-[#030014]/60 backdrop-blur-md border-b border-white/10">
            <div class="max-w-[1100px] mx-auto px-8 py-5 flex items-center justify-between">
                <a href="/" class="gradient-text text-2xl font-extrabold tracking-tight"
                    >The Architect's Blueprint</a
                >
                <div class="flex gap-4 items-center">
                    <button
                        id="trigger-topics-btn"
                        class="relative px-5 py-2.5 rounded-lg font-sans font-semibold text-sm cursor-pointer transition-all duration-300 overflow-hidden bg-white/10 text-white border border-white/20 hover:bg-white/20 hover:border-white/40 hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none disabled:shadow-none"
                    >
                        <span class="relative z-10 btn-text">Generate Topics 💡</span>
                    </button>
                    <button
                        id="trigger-btn"
                        class="relative px-5 py-2.5 rounded-lg font-sans font-semibold text-sm cursor-pointer transition-all duration-300 overflow-hidden bg-linear-to-br from-indigo-400 to-blue-400 text-black border-none shadow-[0_4px_15px_-3px_rgba(167,139,250,0.5)] hover:-translate-y-0.5 hover:scale-105 hover:shadow-[0_6px_20px_-3px_rgba(167,139,250,0.7)] group disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none disabled:shadow-none disabled:hover:scale-100 disabled:hover:translate-y-0"
                    >
                        <div
                            class="absolute inset-0 bg-linear-to-br from-blue-400 to-indigo-400 opacity-0 transition-opacity duration-300 ease-in-out group-hover:opacity-100 z-0"
                        >
                        </div>
                        <span class="relative z-10 btn-text">Generate Post 🪄</span>
                    </button>
                </div>
            </div>
        </nav>
        <main class="max-w-7xl mx-auto px-8 py-12 min-h-[calc(100vh-232px)]">
            <slot />
        </main>
        <footer class="border-t border-white/10 mt-16 p-8 text-center text-zinc-400">
            <div class="text-sm">
                <p>
                    &copy; {new Date().getFullYear()} The Architect's Blueprint. Automagically generated.
                </p>
            </div>
        </footer>

        <script>
            function attachTrigger(btnId: string, endpoint: string, successMsg: string) {
                const btn = document.getElementById(btnId);
                if (btn) {
                    btn.addEventListener("click", async () => {
                        const span = btn.querySelector(".btn-text") as HTMLElement;
                        const originalText = span.innerText;
                        span.innerText = "Triggering...";
                        btn.setAttribute("disabled", "true");

                        try {
                            const res = await fetch(endpoint, { method: "POST" });
                            if (res.ok) {
                                span.innerText = successMsg;
                            } else {
                                span.innerText = "Failed ❌";
                            }
                        } catch {
                            span.innerText = "Error ❌";
                        }

                        setTimeout(() => {
                            span.innerText = originalText;
                            btn.removeAttribute("disabled");
                        }, 5000);
                    });
                }
            }

            attachTrigger("trigger-btn", "/api/trigger", "Pipeline Started! 🚀");
            attachTrigger("trigger-topics-btn", "/api/trigger-topics", "Topics Queued! 🚀");
        </script>
    </body>
</html>
