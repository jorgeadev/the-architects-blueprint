---
import "../styles/global.css";

interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "The Architect's Blueprint - The latest in tech infrastructure and architecture.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <nav class="navbar">
            <div class="nav-content">
                <a href="/" class="brand gradient-text">The Architect's Blueprint</a>
            </div>
        </nav>
        <main>
            <slot />
        </main>
        <footer>
            <div class="footer-content">
                <p>
                    &copy; {new Date().getFullYear()} The Architect's Blueprint. Automagically generated.
                </p>
            </div>
        </footer>
    </body>
</html>

<style>
    .navbar {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(3, 0, 20, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);
    }
    .nav-content {
        max-width: 1100px;
        margin: 0 auto;
        padding: 1.25rem 2rem;
        display: flex;
        align-items: center;
    }
    .brand {
        font-size: 1.5rem;
        font-weight: 800;
        letter-spacing: -0.03em;
    }
    main {
        max-width: 1100px;
        margin: 0 auto;
        padding: 3rem 2rem;
        min-height: calc(100vh - 160px);
    }
    footer {
        border-top: 1px solid var(--border);
        margin-top: 4rem;
        padding: 2rem;
        text-align: center;
        color: var(--text-muted);
    }
    .footer-content {
        font-size: 0.875rem;
    }
</style>
